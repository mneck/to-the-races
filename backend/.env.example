# PostgreSQL (defaults in application.yml)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/totheraces
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres

# Stripe - get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Optional: customize redirect URLs after Stripe checkout
# STRIPE_SUCCESS_URL=http://localhost:5173/checkout/success
# STRIPE_CANCEL_URL=http://localhost:5173/checkout

# JWT secret (min 256 bits for HS256)
# JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-change-in-production
